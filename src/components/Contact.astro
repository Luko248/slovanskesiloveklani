---
import Button from "./ui/Button.astro";
---

<section
  id="contact"
  class="py-20 md:py-36 bg-deep-charcoal relative overflow-hidden scroll-mt-24"
>
  <!-- Atmospheric background layers -->
  <div
    class="absolute inset-0 bg-slavic-pattern opacity-40 pointer-events-none"
  >
  </div>
  <div
    class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-viking-green/50 to-transparent"
  >
  </div>
  <div
    class="absolute bottom-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-viking-green/30 to-transparent"
  >
  </div>
  <!-- Glow orbs -->
  <div
    class="absolute -top-32 -left-32 w-96 h-96 rounded-full bg-viking-green/5 blur-3xl pointer-events-none"
  >
  </div>
  <div
    class="absolute -bottom-32 -right-32 w-96 h-96 rounded-full bg-viking-gold/5 blur-3xl pointer-events-none"
  >
  </div>

  <div class="container mx-auto px-4 relative z-10 max-w-5xl">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <p
        class="text-viking-gold font-display text-sm uppercase tracking-[0.3em] mb-4"
      >
        ⚔ Spojte se s námi ⚔
      </p>
      <div class="inline-flex items-center gap-5 mb-5">
        <span class="contact-line"></span>
        <h2
          class="text-4xl md:text-6xl font-display font-bold text-light-cream leading-tight"
        >
          Kontakt
        </h2>
        <span class="contact-line"></span>
      </div>
      <p class="text-gray-400 text-lg max-w-xl mx-auto leading-relaxed">
        Máte dotazy k soutěži, registraci nebo partnerství?<br
          class="hidden md:block"
        /> Neváhejte se ozvat.
      </p>
    </div>

    <!-- Main Contact Card -->
    <div class="contact-card group">
      <!-- Top accent bar -->
      <div class="contact-accent-bar"></div>

      <div class="contact-grid">
        <!-- Left: Photo -->
        <div class="contact-photo-wrap">
          <div
            class="contact-photo-inner group-hover:scale-105 transition-transform duration-700"
          >
            <img
              src="/images/contact/marek-contact.avif"
              alt="Marek Vidlář — organizátor Slovanského Silového Klání"
              class="w-full h-full object-cover"
              loading="lazy"
            />
            <!-- Photo overlay gradients -->
            <div class="contact-photo-overlay-h"></div>
            <div class="contact-photo-overlay-v"></div>
          </div>

          <!-- Floating badge -->
          <div class="contact-badge scoop-badge">
            <span class="text-xl">🏆</span>
            <div>
              <p class="text-xs text-light-cream font-bold leading-tight">
                5. ročník
              </p>
              <p class="text-xs text-viking-gold leading-tight">
                Hlavní pořadatel
              </p>
            </div>
          </div>
        </div>

        <!-- Right: Info -->
        <div class="contact-info">
          <!-- Name & title -->
          <div class="mb-8">
            <h3
              class="text-3xl md:text-4xl font-display font-bold text-light-cream mb-1"
            >
              Marek Vidlář
            </h3>
            <p
              class="text-viking-gold font-display text-sm uppercase tracking-widest"
            >
              Organizátor události
            </p>
          </div>

          <!-- Description -->
          <div class="space-y-3 text-gray-400 leading-relaxed mb-10">
            <p>
              Hlavní organizátor Slovanského Silového Klání. Pokud máte jakékoli
              otázky k soutěži, kategoriím, registraci nebo spolupráci — jsem tu
              pro vás.
            </p>
            <p class="text-light-cream/70">Rád zodpovím vše, co vás zajímá.</p>
          </div>

          <!-- Contact methods -->
          <div class="contact-methods mb-10">
            <a
              href="mailto:SlovanskeSiloveKlani@gmail.com"
              class="contact-method-item group/item"
              title="Napsat e-mail"
            >
              <div class="contact-method-icon">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="1.5"
                  stroke="currentColor"
                  class="size-5"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"
                  ></path>
                </svg>
              </div>
              <div class="min-w-0">
                <p
                  class="text-xs text-gray-500 uppercase tracking-wider mb-0.5"
                >
                  E-mail
                </p>
                <p
                  class="text-light-cream group-hover/item:text-viking-gold transition-colors duration-200 text-sm font-medium truncate"
                >
                  SlovanskeSiloveKlani@gmail.com
                </p>
              </div>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="2"
                stroke="currentColor"
                class="size-4 text-gray-600 group-hover/item:text-viking-gold group-hover/item:translate-x-1 transition-all duration-200 ml-auto shrink-0"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"></path>
              </svg>
            </a>

            <a
              href="https://www.facebook.com/slovanskesiloveklani"
              target="_blank"
              rel="noopener noreferrer"
              class="contact-method-item group/item"
              title="Facebook"
            >
              <div class="contact-method-icon">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  class="size-5"
                >
                  <path
                    d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878V14.89h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"
                  ></path>
                </svg>
              </div>
              <div class="min-w-0">
                <p
                  class="text-xs text-gray-500 uppercase tracking-wider mb-0.5"
                >
                  Facebook
                </p>
                <p
                  class="text-light-cream group-hover/item:text-viking-gold transition-colors duration-200 text-sm font-medium truncate"
                >
                  Slovanské Silové Klání
                </p>
              </div>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="2"
                stroke="currentColor"
                class="size-4 text-gray-600 group-hover/item:text-viking-gold group-hover/item:translate-x-1 transition-all duration-200 ml-auto shrink-0"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"></path>
              </svg>
            </a>
          </div>

          <!-- CTA -->
          <Button
            href="mailto:SlovanskeSiloveKlani@gmail.com"
            variant="primary"
            size="default"
            class="gap-2.5 w-max"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              class="size-5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"
              ></path>
            </svg>
            Napište mi
          </Button>
        </div>
      </div>
    </div>

    <!-- Bottom location hint -->
    <div class="flex items-center justify-center gap-3 mt-10 text-gray-500">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="currentColor"
        class="size-4 text-viking-green shrink-0"
      >
        <path
          fill-rule="evenodd"
          d="m11.54 22.351.07.04.028.016a.76.76 0 0 0 .723 0l.028-.015.071-.041a16.975 16.975 0 0 0 1.144-.742 19.58 19.58 0 0 0 2.683-2.282c1.944-2.079 3.218-4.407 3.218-7.085V6.733a1 1 0 0 0-.61-.92l-7.5-3.25a1 1 0 0 0-.78 0l-7.5 3.25a1 1 0 0 0-.61.92v5.534c0 2.678 1.274 5.006 3.218 7.085a19.58 19.58 0 0 0 2.682 2.282 16.975 16.975 0 0 0 1.145.742Z"
          clip-rule="evenodd"></path>
      </svg>
      <span class="text-sm"
        >Soutěž se koná v <strong class="text-light-cream/80"
          >Pustiměři, Česká republika</strong
        ></span
      >
    </div>
  </div>
</section>

<style>
  .contact-line {
    display: block;
    height: 2px;
    width: 3rem;
    background: linear-gradient(
      90deg,
      transparent,
      oklch(0.49 0.09 164.29),
      transparent
    );
  }

  /* Main card */
  .contact-card {
    position: relative;
    background: oklch(0.18 0.005 0);
    border: 1px solid oklch(0.49 0.09 164.29 / 0.25);
    overflow: hidden;
    transition:
      border-color 0.4s ease,
      box-shadow 0.4s ease;
  }

  @supports (corner-shape: scoop) {
    .contact-card {
      border-radius: 1.25rem;
      corner-shape: scoop;
    }
  }

  .contact-card:hover {
    border-color: oklch(0.49 0.09 164.29 / 0.5);
    box-shadow:
      0 0 60px oklch(0.49 0.09 164.29 / 0.08),
      0 25px 50px -12px oklch(0 0 0 / 0.5);
  }

  /* Top accent bar with animated gradient */
  .contact-accent-bar {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      oklch(0.49 0.09 164.29) 30%,
      hsl(38.46deg 93.6% 49.02%) 50%,
      oklch(0.49 0.09 164.29) 70%,
      transparent 100%
    );
    background-size: 200% 100%;
    animation: shimmer-bar 4s linear infinite;
    z-index: 1;
  }

  @keyframes shimmer-bar {
    0% {
      background-position: 200% 0;
    }
    100% {
      background-position: -200% 0;
    }
  }

  /* Grid layout */
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
  }

  @media (min-width: 768px) {
    .contact-grid {
      grid-template-columns: 5fr 7fr;
    }
  }

  /* Photo column */
  .contact-photo-wrap {
    position: relative;
    aspect-ratio: 4/3;
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .contact-photo-wrap {
      aspect-ratio: auto;
      min-height: 380px;
    }
  }

  .contact-photo-inner {
    width: 100%;
    height: 100%;
  }

  .contact-photo-inner img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .contact-photo-overlay-h {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      transparent 50%,
      oklch(0.18 0.005 0) 100%
    );
    pointer-events: none;
  }

  .contact-photo-overlay-v {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      transparent 60%,
      oklch(0.18 0.005 0) 100%
    );
    pointer-events: none;
  }

  @media (max-width: 767px) {
    .contact-photo-overlay-v {
      display: none;
    }
    .contact-photo-overlay-h {
      background: linear-gradient(
        to bottom,
        transparent 40%,
        oklch(0.18 0.005 0) 95%
      );
    }
  }

  /* Floating badge */
  .contact-badge {
    position: absolute;
    bottom: 1rem;
    left: 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: oklch(0.12 0 0 / 0.85);
    border: 1px solid oklch(0.49 0.09 164.29 / 0.4);
    backdrop-filter: blur(8px);
    padding: 0.5rem 0.75rem;
  }

  @media (min-width: 768px) {
    .contact-badge {
      bottom: 1.25rem;
      left: 1.25rem;
    }
  }

  /* Info column */
  .contact-info {
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  @media (min-width: 768px) {
    .contact-info {
      padding: 3rem 3rem 3rem 2.5rem;
    }
  }

  /* Contact method rows */
  .contact-methods {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .contact-method-item {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding: 0.875rem 1rem;
    background: oklch(0.12 0 0 / 0.6);
    border: 1px solid oklch(0.49 0.09 164.29 / 0.12);
    border-radius: 0.5rem;
    text-decoration: none;
    transition:
      background 0.2s ease,
      border-color 0.2s ease,
      transform 0.2s ease;
  }

  .contact-method-item:hover {
    background: oklch(0.49 0.09 164.29 / 0.08);
    border-color: oklch(0.49 0.09 164.29 / 0.35);
    transform: translateX(3px);
  }

  .contact-method-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 0.5rem;
    background: oklch(0.49 0.09 164.29 / 0.15);
    color: oklch(0.49 0.09 164.29);
    flex-shrink: 0;
    transition: background 0.2s ease;
  }

  .contact-method-item:hover .contact-method-icon {
    background: oklch(0.49 0.09 164.29 / 0.25);
  }
</style>
